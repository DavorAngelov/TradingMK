    {
      "name": "07 - Submit trade request (Create)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is PENDING', () => pm.expect(pm.response.json().status).to.eql('PENDING'));",
              "pm.collectionVariables.set('trade_id', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stockSymbol\": \"KMB\",\n  \"quantity\": 5,\n  \"pricePerUnit\": 100.0,\n  \"type\": \"BUY\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/trades/request",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trades",
            "request"
          ]
        }
      },
      "response": []
